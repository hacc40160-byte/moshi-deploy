# MoshiRAG Environment Configuration
# Copy to .env and set HF_TOKEN

# HuggingFace token (required for gated Llama 3.2 conditioner model)
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_YOUR_TOKEN_HERE

# LLM Backend (Ollama, zero-cost, CPU-only)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL_NAME=qwen3:4b

# Conditioner service (CPU-only, frees VRAM for main model)
REFERENCE_ENCODER_URL=http://localhost:8001

# MoshiRAG model
MOSHI_REPO=kyutai/moshika-rag-pytorch-bf16
MODEL_DIR=/root/models/moshika-rag

# Ports
MOSHI_PORT=8998
CONDITIONER_PORT=8001
OLLAMA_PORT=11434

# GPU settings
CUDA_DEVICE=cuda:0
BATCH_SIZE=1
