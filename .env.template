# MoshiRAG + Knowledge Base — Environment Config
# Copy to .env and fill in HF_TOKEN

# HuggingFace token (required for model download)
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_YOUR_TOKEN_HERE

# Model config
MOSHI_REPO=kyutai/moshika-rag-pytorch-bf16
MODEL_DIR=/root/models/moshika-rag
CUDA_DEVICE=cuda:0
BATCH_SIZE=1

# Ports
MOSHI_PORT=8999
CONDITIONER_PORT=8001
OLLAMA_PORT=11434

# LLM backend (Ollama with qwen3:4b)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen3:4b
OPENAI_API_KEY=sk-dummy

# Reference encoder (points to conditioner)
REFERENCE_ENCODER_URL=http://localhost:8001
